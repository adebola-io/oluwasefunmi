{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "es2024": true
  },
  "extends": ["./node_modules/retend-oxlint-plugin/recommended.json"],
  "globals": {
    "self": "readonly"
  },
  "categories": {
    "correctness": "warn"
  },
  "rules": {
    "no-unused-vars": "error",
    "no-undef": "error",
    "no-console": "warn",
    "prefer-const": "warn",
    "no-var": "error",
    "eqeqeq": ["warn", "always"],
    "curly": ["warn", "multi-line"],
    "no-debugger": "warn",
    "no-alert": "warn",
    "no-empty": "warn",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-with": "error"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "public/**",
    "vite.config.ts"
  ]
}
